ta-settings=\"{&quot;_animation&quot;:&quot;fadeInUp&quot;}\" data-widget_type=\"elementskit-icon-box.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<div class=\"ekit-wid-con\" >        <!-- link opening -->\n                <!-- end link opening -->\n\n        <div class=\"elementskit-infobox text-left text-left icon-top-align elementor-animation-   \">\n                    <div class=\"elementskit-box-header elementor-animation-\">\n                <div class=\"elementskit-info-box-icon  \">\n                    \n                <\/div>\n          <\/div>\n                        <div class=\"box-body\">\n                            <div class=\"elementskit-info-box-title\">\n                    Richiedi quotazione                <\/div>\n                        \t\t  \t<p>Compila il form per ottenere la tua quotazione personalizzata<\/p>\n                                        <div class=\"box-footer disable_hover_button\">\n                    <div class=\"btn-wraper\">\n                                                            <a class=\"elementskit-btn whitespace--normal\" href=\"https:\/\/sistemaspedizioni.it\/richiesta-quotazione\/\">\n                                        <i aria-hidden=\"true\" class=\"icomoon icomoon-compass\"><\/i>                                        Quotazione                                    <\/a>\n                                                        <\/div>\n                <\/div>\n                    <\/div>\n        \n        \n                <\/div>\n        <\/div>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-3af8003 ekit-equal-height-disable elementor-invisible elementor-widget elementor-widget-elementskit-icon-box\" data-id=\"3af8003\" data-element_type=\"widget\" data-e-type=\"widget\" data-settings=\"{&quot;_animation&quot;:&quot;fadeInUp&quot;}\" data-widget_type=\"elementskit-icon-box.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<div class=\"ekit-wid-con\" >        <!-- link opening -->\n                <!-- end link opening -->\n\n        <div class=\"elementskit-infobox text-left text-left icon-top-align elementor-animation-   \">\n                    <div class=\"elementskit-box-header elementor-animation-\">\n                <div class=\"elementskit-info-box-icon  \">\n                    \n                <\/div>\n          <\/div>\n                        <div class=\"box-body\">\n                            <div class=\"elementskit-info-box-title\">\n                    Necessiti di aiuto?                <\/div>\n                        \t\t  \t<p>Possiamo soddisfare ogni esigenza di spedizione<\/p>\n                                        <div class=\"box-footer disable_hover_button\">\n                    <div class=\"btn-wraper\">\n                                                            <a class=\"elementskit-btn whitespace--normal\" href=\"https:\/\/sistemaspedizioni.it\/contatti\/\">\n                                        <i aria-hidden=\"true\" class=\"icomoon icomoon-phone\"><\/i>                                        Contatti                                    <\/a>\n                                                        <\/div>\n                <\/div>\n                    <\/div>\n        \n        \n                <\/div>\n        <\/div>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-6ace3f1 e-con-full e-flex e-con e-child\" data-id=\"6ace3f1\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-8b3d7e3 elementor-widget elementor-widget-heading\" data-id=\"8b3d7e3\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"heading.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t<h2 class=\"elementor-heading-title elementor-size-default\">Road Transport<\/h2>\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-8f1f781 elementor-widget elementor-widget-text-editor\" data-id=\"8f1f781\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p>Le nostre flotte di trasporto, moderne e costantemente monitorate, garantiscono affidabilit\u00e0 e sicurezza.<\/p><p>Radicati profondamente nel territorio, ci impegniamo a espandere continuamente i nostri orizzonti oltre confine.<\/p><p>Trasportiamo una vasta gamma di merci, dalle pi\u00f9 fragili alle pi\u00f9 ingombranti, inclusi macchinari di grandi dimensioni. Sfida le nostre capacit\u00e0!<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<div class=\"elementor-element elementor-element-89b4ced elementor-widget elementor-widget-text-editor\" data-id=\"89b4ced\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"text-editor.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t<p><strong>Carichi completi (FTL)<\/strong><\/p><p>Sistema Spedizioni garantisce le migliori tariffe per il trasporto di carichi completi, la soluzione pi\u00f9 veloce, economica ed efficace per il trasporto diretto da voi al vostro cliente.<\/p><p><strong>Camion parziali (LTL)<\/strong><\/p><p>La nostra esperienza e la rete di partner specializzati con cui interagiamo ci permette di organizzare camion parziali a presa diretta ottimizzando i costi e le tempistiche, senza tappe intermedie.<\/p><p><strong>Servizio espresso<\/strong><\/p><p>Siamo in grado di supportarvi con servizi di trasporto espresso con furgone e autista a vostro uso esclusivo per servizi di emergenza.<\/p><p><strong>Groupage <\/strong><\/p><p>Siamo specializzati nel groupage. Abbiamo grande cura di ci\u00f2 che trasportiamo e ci affidiamo a partner competenti, precisi e puntali, offrendo diverse partenze settimanali per tutta Europa.<\/p><p><strong>Trasporti eccezionali<\/strong><\/p><p>Il nostro team \u00e8 in grado di organizzare con estrema professionalit\u00e0 in tutta Europa ed Italia trasporti non convenzionali che necessitano di automezzi eccezionali. \u00a0\u00a0<\/p><p><strong>Servizio fiere\/eventi<\/strong><\/p><p>Siamo attrezzati per il trasporto della vostra merce in occasione di eventi fieristici e manifestazioni. La nostra tempestivit\u00e0 e precisione garantiscono la perfetta gestione logistica del vostro business.<\/p>\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-e3c97a9 e-con-full e-flex e-con e-child\" data-id=\"e3c97a9\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t<div class=\"elementor-element elementor-element-6349716 e-con-full e-flex e-con e-child\" data-id=\"6349716\" data-element_type=\"container\" data-e-type=\"container\">\n\t\t\t\t<div class=\"elementor-element elementor-element-4c47962 elementor-widget elementor-widget-image\" data-id=\"4c47962\" data-element_type=\"widget\" data-e-type=\"widget\" data-widget_type=\"image.default\">\n\t\t\t\t<div class=\"elementor-widget-container\">\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<a href=\"https:\/\/sistemaspedizioni.it\/wp-content\/uploads\/2024\/01\/sede2small.jpg\" data-elementor-open-lightbox=\"yes\" data-elementor-lightbox-title=\"sede2small\" data-e-action-hash=\"#elementor-action%3Aaction%3Dlightbox%26settings%3DeyJpZCI6ODMsInVybCI6Imh0dHBzOlwvXC9zaXN0ZW1hc3BlZGl6aW9uaS5pdFwvd3AtY29udGVudFwvdXBsb2Fkc1wvMjAyNFwvMDFcL3NlZGUyc21hbGwuanBnIn0%3D\">\n\t\t\t\t\t\t\t<img fetchpriority=\"high\" decoding=\"async\" width=\"600\" height=\"400\" src=\"https:\/\/sistemaspedizioni.it\/wp-content\/uploads\/2024\/01\/sede2small.jpg\" class=\"attachment-full size-full wp-image-83\" alt=\"\" \/>\t\t\t\t\t\t\t\t<\/a>\n\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t\t\t<\/div>\n\t\t<div class=\"elementor-element elementor-element-4c59fcd e-con-full e-flex e-con e-child\" data-id=\"4c59fcd\" data-